# ==============================================================================
# Media Center Configuration
# These values are auto-detected by setup.sh — only edit if you need overrides.
# ==============================================================================

# --- System (auto-detected by setup.sh) ---
PUID=__PUID__
PGID=__PGID__
TZ=__TZ__
UMASK=002

# --- Paths (auto-detected by setup.sh) ---
DATA_PATH=__DATA_PATH__
APPDATA_PATH=__APPDATA_PATH__

# --- VPN (Gluetun) ---
# Provider: "expressvpn" or "nordvpn" (see https://github.com/qdm12/gluetun-wiki)
VPN_SERVICE_PROVIDER=nordvpn
VPN_TYPE=openvpn

# OpenVPN credentials (for both ExpressVPN and NordVPN with OpenVPN)
OPENVPN_USER=
OPENVPN_PASSWORD=

# For NordVPN with WireGuard: set VPN_TYPE=wireguard and uncomment below
# WIREGUARD_PRIVATE_KEY=
# SERVER_COUNTRIES=United States

# For ExpressVPN: set VPN_SERVICE_PROVIDER=expressvpn
# EXPRESSVPN_ACTIVATION_CODE=

# --- Plex (running on host, not in Docker) ---
PLEX_URL=http://192.168.1.100:32400
# Plex token is needed for Overseerr auto-setup (standard+ tier).
# To find yours: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# If left empty, Overseerr setup is skipped (you can configure it manually in the UI).
PLEX_TOKEN=

# --- qBittorrent ---
QB_USERNAME=admin
QB_PASSWORD=mediaCenter!2026

# --- API Keys (auto-populated by setup.sh after first run) ---
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=
LIDARR_API_KEY=
READARR_API_KEY=
